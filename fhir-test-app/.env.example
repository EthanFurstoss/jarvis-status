# PointClickCare FHIR API credentials
# ------------------------------------
# Copy this file to ".env" and fill in the values from your PointClickCare
# Developer Program app listing ("My Apps").
#
# Leave these BLANK to run the app in mock mode (bundled de-identified FHIR
# test data, no network calls). As soon as PCC_CLIENT_ID and PCC_CLIENT_SECRET
# are set, the app switches to live calls against the PCC FHIR Sandbox.

# OAuth2 client credentials issued by PointClickCare for your app
PCC_CLIENT_ID=
PCC_CLIENT_SECRET=

# OAuth2 token endpoint (system/server-to-server "client_credentials" flow).
# Confirm the exact host/path against your app's listing in the developer portal.
PCC_TOKEN_URL=https://connect.pointclickcare.com/auth/token

# FHIR R4 base URL for the Sandbox environment.
PCC_FHIR_BASE_URL=https://fhir.pointclickcare.com/r4

# Space-separated SMART on FHIR scopes your app is approved for.
PCC_SCOPES=system/Patient.read system/Condition.read system/Observation.read system/MedicationRequest.read system/AllergyIntolerance.read

# Local server port
PORT=3000
